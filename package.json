{
  "name": "creative-canvas",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev --filter=web",
    "build": "turbo run build --filter=web",
    "lint": "turbo run lint --filter=web",
    "typecheck": "turbo run typecheck --filter=web",
    "test": "turbo run test --filter=web",
    "dev:web": "turbo run dev --filter=web",
    "build:web": "turbo run build --filter=web",
    "lint:web": "turbo run lint --filter=web",
    "typecheck:web": "turbo run typecheck --filter=web",
    "test:web": "turbo run test --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "build:api": "turbo run build --filter=api",
    "lint:api": "turbo run lint --filter=api",
    "typecheck:api": "turbo run typecheck --filter=api",
    "build:all": "turbo run build",
    "lint:all": "turbo run lint",
    "typecheck:all": "turbo run typecheck",
    "test:all": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "@types/node": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "latest"
  }
}
