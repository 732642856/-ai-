# ============================================================================
# StarCanvas — AI Provider 配置模板
# ============================================================================
# 复制此文件为 .env.local 并填写你的中转站配置。
# 支持任何 OpenAI 兼容协议的中转站。
# ============================================================================

# ── 必填 ──────────────────────────────────────────────────────────────────

# 中转站 Base URL（OpenAI 兼容协议）
AI_BASE_URL=https://your-proxy.example.com/v1

# 中转站 API Key
AI_API_KEY=sk-your-key-here

# 默认文本模型
AI_DEFAULT_MODEL=gpt-4o-mini

# ── 可选 ──────────────────────────────────────────────────────────────────

# 默认图片模型（不配则走 AI_DEFAULT_MODEL）
AI_DEFAULT_IMAGE_MODEL=gpt-image-2

# 视频分析专用模型（不配则走 AI_DEFAULT_MODEL）
# 注意：部分中转站可能不支持 video_url，如果失败请确保模型支持
AI_VIDEO_MODEL=

# 请求超时（毫秒）
AI_REQUEST_TIMEOUT_MS=120000

# ── 旧版兼容（逐步迁移到上方 AI_ 变量） ──────────────────────────────────

# NEXT_PUBLIC_API_BASE_URL=https://your-proxy.example.com/v1
# OPENAI_API_KEY=sk-your-key-here
# NEXT_PUBLIC_USE_MOCK=false
