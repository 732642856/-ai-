    "@lancedb/lancedb": "^0.30.0",
    "@mastra/core": "^1.41.0",
    "@mixvideo/jianying": "^1.0.0",
    "@sentry/nextjs": "^10.56.0",
    "@xenova/transformers": "^2.17.2",
    "@xyflow/react": "^12.10.0",
    "@xzdarcy/react-timeline-editor": "^1.0.0",
    "ai": "^6.0.198",
    "dagre": "^0.8.5",
    "iztro": "^2.5.8",
    "kokoro-js": "^1.2.1",
    "leva": "^0.10.1",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "next": "16.2.6",
