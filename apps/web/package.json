{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS='' node --test --experimental-strip-types 'src/**/*.test.ts'",
    "test:e2e": "pnpm dlx @playwright/test@1.58.0 test --config=playwright.config.ts",
    "test:e2e:storyboard": "pnpm dlx @playwright/test@1.58.0 test --config=playwright.config.ts e2e/storyboard-direct-only.spec.ts",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:all": "npm run test && npm run test:vitest"
  },
  "dependencies": {
    "@creative-canvas/canvas": "workspace:*",
    "@sentry/nextjs": "^10.56.0",
    "@xyflow/react": "^12.10.0",
    "dagre": "^0.8.5",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-canvas-masker": "1.2.0",
    "react-dom": "19.2.4",
    "react-dropzone": "14.3.0",
    "recharts": "2.15.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/dagre": "^0.7.52",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "react-scan": "^0.5.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
