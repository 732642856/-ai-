# ── StarCanvas Voice Clone Service ──
# Copy this file to .env and fill in your values.
# cp .env.example .env

# HuggingFace Space URL for OmniVoice backend.
# Default: official F5-TTS Space (no API key needed for public Spaces)
OMNIVOICE_SPACE_URL=https://mrfakename-f5-tts.hf.space

# Optional: HuggingFace API token for private Spaces or higher rate limits
# HF_TOKEN=your_huggingface_token_here

# Data directory for voice profiles and audio (mounted as Docker volume)
VOICE_CLONE_DATA_DIR=/app/data/voice_clone

# Maximum upload size in bytes (default: 20 MB)
MAX_UPLOAD_BYTES=20971520

# Log level
LOG_LEVEL=info
