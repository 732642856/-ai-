generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum BillingMode {
  PLATFORM_CREDITS
  BYOK_PERSONAL
  BYOK_ORGANIZATION
}

enum ProviderType {
  OPENAI_COMPATIBLE
  OPENAI
  ANTHROPIC
  DEEPSEEK
  GEMINI
  FAL
  REPLICATE
  STABILITY
}

enum CanvasNodeType {
  TEXT
  PROMPT
  IMAGE
  RESULT
  NOTE
  CHARACTER
  SCENE
  STORYBOARD
  PREVIS_3D
  VIDEO
  GENERATION_TASK
}

enum GenerationStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

model User {
  id             String                   @id @default(cuid())
  email          String                   @unique
  name           String?
  passwordHash   String?
  avatarUrl      String?
  memberships    OrganizationMember[]
  projects       Project[]                @relation("ProjectOwner")
  providerKeys   ProviderCredential[]
  generationJobs GenerationJob[]
  usageRecords   UsageRecord[]
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
}

model Organization {
  id                  String                   @id @default(cuid())
  name                String
  slug                String                   @unique
  members             OrganizationMember[]
  projects            Project[]
  providerCredentials ProviderCredential[]
  usageRecords        UsageRecord[]
  creditLedger        CreditLedgerEntry[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
}

model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@unique([organizationId, userId])
  @@index([userId])
}

model Project {
  id             String          @id @default(cuid())
  organizationId String
  ownerId        String
  name           String
  description    String?
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner          User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  canvases       CanvasDocument[]
  generationJobs GenerationJob[]
  usageRecords   UsageRecord[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId])
  @@index([ownerId])
}

model CanvasDocument {
  id        String          @id @default(cuid())
  projectId String
  name      String          @default("默认画布")
  nodes     Json            @default("[]")
  edges     Json            @default("[]")
  viewport  Json            @default("{\"x\":0,\"y\":0,\"zoom\":1}")
  version   Int             @default(1)
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions  CanvasVersion[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([projectId])
}

model CanvasVersion {
  id        String         @id @default(cuid())
  canvasId  String
  version   Int
  title     String?
  reason    String?
  nodes     Json
  edges     Json
  viewport  Json
  metadata  Json?
  canvas    CanvasDocument @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@index([canvasId, createdAt])
  @@unique([canvasId, version])
}

model ProviderCredential {
  id             String        @id @default(cuid())
  organizationId String?
  userId         String?
  type           ProviderType
  name           String
  baseUrl        String?
  encryptedKey   String
  defaultModel   String?
  isEnabled      Boolean       @default(true)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationJobs GenerationJob[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@index([userId])
}

model GenerationJob {
  id                   String              @id @default(cuid())
  organizationId        String
  projectId             String?
  userId                String
  providerCredentialId  String?
  providerType          ProviderType
  model                 String
  billingMode           BillingMode
  status                GenerationStatus   @default(PENDING)
  input                 Json
  output                Json?
  errorMessage          String?
  inputTokens           Int?
  outputTokens          Int?
  estimatedCostCny      Decimal?           @db.Decimal(12, 4)
  project               Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user                  User               @relation(fields: [userId], references: [id])
  providerCredential    ProviderCredential? @relation(fields: [providerCredentialId], references: [id], onDelete: SetNull)
  usageRecords          UsageRecord[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([userId])
  @@index([status])
}

model UsageRecord {
  id              String        @id @default(cuid())
  organizationId  String
  projectId       String?
  userId          String
  generationJobId String?
  billingMode     BillingMode
  providerType    ProviderType
  model           String
  inputTokens     Int           @default(0)
  outputTokens    Int           @default(0)
  creditsUsed     Int           @default(0)
  estimatedCostCny Decimal?     @db.Decimal(12, 4)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user            User          @relation(fields: [userId], references: [id])
  generationJob   GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
}

model CreditLedgerEntry {
  id             String       @id @default(cuid())
  organizationId String
  delta          Int
  balanceAfter   Int
  reason         String
  metadata       Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}
